{
  "manifest_version": 3,
  "name": "Native Control",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": { "id": "control@nil.com" }
  },
  "permissions":[
    "nativeMessaging",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts":["background.js"]
  }
}
